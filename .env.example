# Copy to .env and adjust. NEVER commit your real .env.

# Host port mapped to the container (compose). The app listens on 8090 inside.
HOST_PORT=8091

# Brand shown in the UI (e.g. "World Cup Pool", "Office Pool 2026").
AEWC_BRAND=AEWC26

# Starting wallet balance for new players.
AEWC_START_BALANCE=100000

# Admin account password (username is "admin"). If empty, a random one is
# generated and printed to the logs on first boot.
AEWC_ADMIN_PASSWORD=

# Set to 1 to also seed 4 demo players (password "demo1234") for a quick try.
AEWC_SEED_DEMO=0

# Display timezone for kickoff times (IANA name).
AEWC_TZ=Asia/Ho_Chi_Minh

# Optional: The Odds API key (https://the-odds-api.com, free 500 req/mo) to
# show bookmaker reference odds AND auto-pull match results. Leave empty to
# disable both (you can still enter results manually in /admin).
ODDS_API_KEY=
