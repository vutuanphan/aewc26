# Copy to .env and adjust. NEVER commit your real .env.

# Host port mapped to the container (compose). The app listens on 8090 inside.
HOST_PORT=8091

# Brand shown in the UI (e.g. "World Cup Pool", "Office Pool 2026").
AEWC_BRAND=AEWC26

# Starting wallet balance for new players.
AEWC_START_BALANCE=100000

# Admin account password (username is "admin"). If empty, a random one is
# generated and printed to the logs on first boot.
AEWC_ADMIN_PASSWORD=

# Set to 1 to also seed 4 demo players (password "demo1234") for a quick try.
AEWC_SEED_DEMO=0

# Display timezone for kickoff times (IANA name).
AEWC_TZ=Asia/Ho_Chi_Minh

# Where live + final scores come from (for settlement):
#   espn    - ESPN's free public scoreboard. No key, no quota. (default)
#   oddsapi - The Odds API /scores (needs ODDS_API_KEY).
AEWC_RESULTS_SOURCE=espn

# How often to poll live scores while a match is on, in seconds (min 20).
AEWC_LIVE_POLL_SECONDS=120

# Optional: The Odds API key (https://the-odds-api.com, free 500 req/mo).
# Only needed for BOOKMAKER REFERENCE ODDS in the create-bet form (1x2 /
# handicap / over-under). Results do NOT need it when AEWC_RESULTS_SOURCE=espn.
# Note: each odds refresh costs (markets x regions) credits, so the app
# refreshes odds only ~every 6h to stay within the free tier.
ODDS_API_KEY=
